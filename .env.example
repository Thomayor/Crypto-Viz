# =====================================
# CRYPTO VIZ - Variables d'environnement
# =====================================

# Copiez ce fichier vers .env et remplissez les valeurs

# ======================
# SUPABASE CONFIGURATION
# ======================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ======================
# EXTERNAL APIS
# ======================

# CoinMarketCap API (requis pour données crypto)
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key

# NewsAPI (requis pour actualités)
NEWS_API_KEY=your-news-api-key

# Reddit API (requis pour social sentiment scraper)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=CryptoViz/1.0

# Twitter API (optionnel pour sentiment)
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# CryptoCompare API (optionnel, alternative à CoinGecko)
CRYPTOCOMPARE_API_KEY=your-cryptocompare-api-key

# ======================
# KAFKA CONFIGURATION
# ======================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_GROUP_ID=crypto-viz-consumers
KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=10

# ======================
# SPARK CONFIGURATION
# ======================
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_EXECUTOR_MEMORY=1g
SPARK_EXECUTOR_CORES=1
SPARK_MAX_CORES=4

# ======================
# OLLAMA CONFIGURATION
# ======================
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_TIMEOUT=30
OLLAMA_TEMPERATURE=0.0
OLLAMA_MAX_TOKENS=150

# ======================
# DATABASE CONFIGURATION
# ======================

# PostgreSQL (primary long-term storage)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=crypto_viz
POSTGRES_PASSWORD=crypto_viz_password
POSTGRES_DB=crypto_analytics

# DuckDB (analytics and fast queries)
DUCKDB_PATH=/app/data/crypto_analytics.db
DUCKDB_MEMORY_LIMIT=2GB
DUCKDB_THREADS=4

# ======================
# SCRAPING CONFIGURATION
# ======================
# Crypto price scraper (60 seconds)
SCRAPER_INTERVAL=1800
SCRAPER_BATCH_SIZE=100
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT=10

# Social sentiment scraper (10 minutes = 600s)
SOCIAL_SCRAPER_INTERVAL=1800

# Liste des cryptomonnaies à surveiller (6 cryptos, hors stablecoins)
# BTC, ETH, BNB, SOL, ADA, DOT
CRYPTO_SYMBOLS=bitcoin,ethereum,binancecoin,solana,cardano,polkadot
CRYPTO_COUNT=6

# ======================
# ANALYTICS CONFIGURATION
# ======================
ANALYTICS_INTERVAL=1800
SENTIMENT_BATCH_SIZE=10
CACHE_TTL=1800

# ======================
# BACKEND CONFIGURATION
# ======================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
LOG_LEVEL=INFO

# JWT pour authentification (générez une clé sécurisée)
JWT_SECRET_KEY=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ======================
# FRONTEND CONFIGURATION
# ======================
VUE_APP_BACKEND_URL=http://localhost:8000
VUE_APP_WEBSOCKET_URL=ws://localhost:8000/ws
VUE_APP_SUPABASE_URL=${SUPABASE_URL}
VUE_APP_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# ======================
# MONITORING & LOGGING
# ======================
LOG_LEVEL=INFO
ENABLE_METRICS=true
METRICS_PORT=9090

# ======================
# RESOURCE LIMITS
# ======================
MAX_MEMORY_USAGE=4GB
MAX_CPU_USAGE=2

# ======================
# DEVELOPMENT SETTINGS
# ======================
DEBUG=false
RELOAD=true
WORKERS=1

# ======================
# PRODUCTION SETTINGS
# ======================
# Uncomment for production
# DEBUG=false
# RELOAD=false
# WORKERS=4
# SECURE_SSL_REDIRECT=true